{
  "pkg": "@depot/web",
  "globalName": "DepotUI",
  "projectId": "563575a1-2115-4383-82cc-319c4b48ca09",
  "shape": "package",
  "buildCmd": "node .design-sync/prepare-build.mjs",
  "tsconfig": "tsconfig.json",
  "cssEntry": "dist/ds-styles.css",
  "provider": {
    "component": "MemoryRouter",
    "props": { "initialEntries": ["/factions/adeptus-astartes/intercessor-squad"] }
  },
  "extraEntries": ["./.ds-providers.tsx"],
  "libOverrides": {
    "source-kit.mjs": "neutralize path-based group derivation so cfg.docsMap category frontmatter is the single source of component grouping"
  },
  "readmeHeader": ".design-sync/conventions.md",
  "overrides": {
    "ContentCard": { "cardMode": "column" },
    "StatCard": { "cardMode": "column" },
    "StatsRow": { "cardMode": "column" },
    "PageHeaderSkeleton": { "cardMode": "column" },
    "TabsSkeleton": { "cardMode": "column" },
    "Drawer": { "cardMode": "single", "primaryStory": "OpenRight" }
  },
  "docsMap": {
    "Button": "../../.design-sync/groups/actions.md",
    "IconButton": "../../.design-sync/groups/actions.md",
    "ActionGroup": "../../.design-sync/groups/actions.md",
    "Field": "../../.design-sync/groups/forms.md",
    "SelectField": "../../.design-sync/groups/forms.md",
    "Search": "../../.design-sync/groups/forms.md",
    "Filters": "../../.design-sync/groups/forms.md",
    "ToggleSwitch": "../../.design-sync/groups/forms.md",
    "QuantityStepper": "../../.design-sync/groups/forms.md",
    "Alert": "../../.design-sync/groups/feedback.md",
    "Toast": "../../.design-sync/groups/feedback.md",
    "Loader": "../../.design-sync/groups/feedback.md",
    "ErrorState": "../../.design-sync/groups/feedback.md",
    "Skeleton": "../../.design-sync/groups/feedback.md",
    "SkeletonCard": "../../.design-sync/groups/feedback.md",
    "PageHeaderSkeleton": "../../.design-sync/groups/feedback.md",
    "TabsSkeleton": "../../.design-sync/groups/feedback.md",
    "FieldSkeleton": "../../.design-sync/groups/feedback.md",
    "Card": "../../.design-sync/groups/data-display.md",
    "ContentCard": "../../.design-sync/groups/data-display.md",
    "LinkCard": "../../.design-sync/groups/data-display.md",
    "StatCard": "../../.design-sync/groups/data-display.md",
    "StatsRow": "../../.design-sync/groups/data-display.md",
    "Table": "../../.design-sync/groups/data-display.md",
    "Tag": "../../.design-sync/groups/data-display.md",
    "PointsTag": "../../.design-sync/groups/data-display.md",
    "Breadcrumbs": "../../.design-sync/groups/navigation.md",
