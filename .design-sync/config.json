    "Breadcrumbs": "src/components/ui/breadcrumbs/index.tsx",
    "Button": "src/components/ui/button/index.tsx",
    "Card": "src/components/ui/card/index.tsx",
    "CollapsibleSection": "src/components/ui/collapsible-section/index.tsx",
    "ContentCard": "src/components/ui/content-card/index.tsx",
    "Drawer": "src/components/ui/drawer/index.tsx",
